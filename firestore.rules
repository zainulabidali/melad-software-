rules_version = '2';

service cloud.firestore {

match /databases/{database}/documents {


// =====================================================
// AUTH HELPERS
// =====================================================

function isAuthenticated() {
  return request.auth != null;
}

function userDoc() {
  return get(
    /databases/$(database)/documents/users/$(request.auth.uid)
  );
}

function userExists() {
  return isAuthenticated() &&
         exists(
           /databases/$(database)/documents/users/$(request.auth.uid)
         );
}

function userData() {
  return userDoc().data;
}

function instituteDoc(instituteId) {
  return get(
    /databases/$(database)/documents/institutes/$(instituteId)
  );
}

function instituteExists(instituteId) {
  return exists(
    /databases/$(database)/documents/institutes/$(instituteId)
  );
}

function instituteData(instituteId) {
  return instituteDoc(instituteId).data;
}

// =====================================================
// ROLE CHECKS
// =====================================================

function isSuperAdmin() {
  return userExists()
    && userData().role == "super_admin";
}

function isAdmin() {
  return userExists()
    && userData().role == "admin";
}

// =====================================================
// INSTITUTE CHECKS
// =====================================================

function isInstituteActive(instituteId) {
  return instituteExists(instituteId)
    && instituteData(instituteId).status == "active";
}

function isInstituteNotExpired(instituteId) {
  return instituteExists(instituteId)
    && (
      !("expiryDate" in instituteData(instituteId))
      ||
      instituteData(instituteId).expiryDate == null
      ||
      !(instituteData(instituteId).expiryDate is timestamp)
      ||
      instituteData(instituteId).expiryDate > request.time
    );
}

function isInstituteAdmin(instituteId) {
  return isAdmin()
    && userData().instituteId == instituteId
    && isInstituteActive(instituteId)
    && isInstituteNotExpired(instituteId);
}

// =====================================================
// USERS
// =====================================================

match /users/{userId} {

  allow read:
  if isAuthenticated()
  &&
  (
    request.auth.uid == userId
    ||
    isSuperAdmin()
  );

  allow create, update, delete:
  if isSuperAdmin();
}

// =====================================================
// PENDING ADMINS
// =====================================================

match /pending_admins/{uid} {

  allow create:
  if isAuthenticated()
  && request.auth.uid == uid;

  allow read, update, delete:
  if isSuperAdmin();
}

// =====================================================
// TEACHERS
// =====================================================

match /teachers/{uid} {

  allow create:
  if isAuthenticated()
  && request.auth.uid == uid
  && request.resource.data.fullName is string
  && request.resource.data.email is string
  && request.resource.data.phone is string
  && request.resource.data.place is string
  && request.resource.data.status == "pending";

  allow read:
  if isAuthenticated()
  &&
  (
    request.auth.uid == uid
    ||
    isSuperAdmin()
  );

  allow update, delete:
  if isSuperAdmin();
}

// =====================================================
// CONFIG
// =====================================================

match /config/{docId} {

  allow read: if true;

  allow write:
  if isSuperAdmin();
}

// =====================================================
// INSTITUTES
// =====================================================

match /institutes/{instituteId} {

  allow read: if true;

  allow create, update, delete:
  if isSuperAdmin();

  // -----------------------------
  // CATEGORIES
  // -----------------------------

  match /categories/{categoryId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // STUDENTS
  // -----------------------------

  match /students/{studentId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // PROGRAMS
  // -----------------------------

  match /programs/{programId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    match /participants/{participantId} {

      allow read, create, update, delete:
      if isInstituteAdmin(instituteId)
      || isSuperAdmin();
    }
  }

  // -----------------------------
  // TEAMS (OLD STRUCTURE SUPPORT)
  // -----------------------------

  match /teams/{teamId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    match /categories/{categoryId} {

      allow read, create, update, delete:
      if isInstituteAdmin(instituteId)
      || isSuperAdmin();

      match /students/{studentId} {

        allow read, create, update, delete:
        if isInstituteAdmin(instituteId)
        || isSuperAdmin();
      }
    }
  }

  // -----------------------------
  // RESULTS
  // -----------------------------

  match /results/{resultId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // MARK ENTRIES
  // -----------------------------

  match /markEntries/{entryId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // JUDGES
  // -----------------------------

  match /judges/{judgeId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // EXPORTS
  // -----------------------------

  match /exports/{exportId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // TOP SCORERS
  // -----------------------------

  match /topScorers/{docId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // METADATA
  // -----------------------------

  match /metadata/{docId} {

    allow read, write:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // RECOVERY BIN
  // -----------------------------

  match /recoveryBin/{docId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // MIGRATION STATUS
  // -----------------------------

  match /migrationStatus/{docId} {

    allow read:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    allow write:
    if isSuperAdmin();
  }
}

// =====================================================
// COLLECTION GROUP PARTICIPANTS
// =====================================================

match /{path=**}/participants/{participantId} {

  allow read:
  if isAuthenticated();
}

// =====================================================
// DEFAULT DENY
// =====================================================

match /{document=**} {
  allow read, write: if false;
}


}
}
