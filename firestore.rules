+  if isSuperAdmin();
}

// =====================================================
// CONFIG
// =====================================================

match /config/{docId} {

  allow read: if true;

  allow write:
  if isSuperAdmin();
}

// =====================================================
// INSTITUTES
// =====================================================

match /institutes/{instituteId} {

  allow read: if true;

  allow create, update, delete:
  if isSuperAdmin();

  // -----------------------------
  // CATEGORIES
  // -----------------------------

  match /categories/{categoryId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // STUDENTS
  // -----------------------------

  match /students/{studentId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // PROGRAMS
  // -----------------------------

  match /programs/{programId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    match /participants/{participantId} {

      allow read: if true;

      allow create, update, delete:
      if isInstituteAdmin(instituteId)
      || isSuperAdmin();
    }
  }

  // -----------------------------
  // TEAMS (OLD STRUCTURE SUPPORT)
  // -----------------------------

  match /teams/{teamId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    match /categories/{categoryId} {

      allow read, create, update, delete:
      if isInstituteAdmin(instituteId)
      || isSuperAdmin();

      match /students/{studentId} {

        allow read, create, update, delete:
        if isInstituteAdmin(instituteId)
        || isSuperAdmin();
      }
    }
  }

  // -----------------------------
  // RESULTS
  // -----------------------------

  match /results/{resultId} {

    allow read, create, update: if true;

    allow delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // MARK ENTRIES
  // -----------------------------

  match /markEntries/{entryId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // JUDGES
  // -----------------------------

  match /judges/{judgeId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // EXPORTS
  // -----------------------------

  match /exports/{exportId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // SCHEDULES
  // -----------------------------

  match /schedules/{scheduleId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // STAGES
  // -----------------------------

  match /stages/{stageId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // TOP SCORERS
  // -----------------------------

  match /topScorers/{docId} {

    allow read: if true;

    allow create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // METADATA
  // -----------------------------

  match /metadata/{docId} {

    allow read: if true;

    allow write:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // RECOVERY BIN
  // -----------------------------

  match /recoveryBin/{docId} {

    allow read, create, update, delete:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();
  }

  // -----------------------------
  // MIGRATION STATUS
  // -----------------------------

  match /migrationStatus/{docId} {

    allow read:
    if isInstituteAdmin(instituteId)
    || isSuperAdmin();

    allow write:
    if isSuperAdmin();
  }
}

// =====================================================
// COLLECTION GROUP PARTICIPANTS
// =====================================================

match /{path=**}/participants/{participantId} {

  allow read:
  if isAuthenticated();
}

// =====================================================
// DEFAULT DENY
// =====================================================

match /{document=**} {
  allow read, write: if false;
}


}
}
